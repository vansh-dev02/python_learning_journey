# Personal chat assistant in Python
# Rule based chatbot

import datetime
import time


# Welcome
name = input("Welcome, Please tell your name: ")

presentHour = datetime.datetime.now().hour

if 5 <= presentHour < 12:
    print("Good Morning,", name)

elif 12 <= presentHour < 17:
    print("Good Afternoon,", name)

elif 17 <= presentHour < 21:
    print("Good Evening,", name)

else:
    print("Good Night,", name)


print("\nHello! Welcome to your personal chatbot")
print("Ask me basic questions. Type 'bye' to exit\n")


# Chatbot memory

responses = {
    "hello": "Hi, How can I help you?",
    "how are you": "I am fine. Thank you!",
    "motivate me": "Keep going. Every bug makes you a better programmer.",
    "happy": "Great to hear that!",
    "what are functions": "Functions are reusable blocks of code in Python.",
    "who are you": "I am your smart AI chatbot.",
    "your name": "I am a Python based chatbot."
}


# Response function

def get_response(user_question):

    user_question = user_question.lower()

    for key in responses:

        if key in user_question:
            return responses[key]

    return "I don't know that yet. I am still learning."


# Main chatbot loop

while True:

    user_input = input("You: ")

    time.sleep(1)   # 1 second delay

    if "bye" in user_input.lower():
        print("Bot: Goodbye! Have a nice day.")
        break

    reply = get_response(user_input)

    print("Bot:", reply)